local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if not checkcaller() and Config.AvatarSpoofEnabled and Config.TargetAvatarId ~= 0 then
        if self == LocalPlayer then
            if key == "CharacterAppearanceId" then
                return Config.TargetAvatarId
            elseif key == "HasAppearanceLoaded" then
                return true
            end
        end
    end
    return oldIndex(self, key)
end)

local oldGetDescription
oldGetDescription = hookfunction(Players.GetHumanoidDescriptionFromUserId, function(self, userId)
    if Config.AvatarSpoofEnabled and Config.TargetAvatarId ~= 0 and userId == LocalPlayer.UserId then
        return oldGetDescription(self, Config.TargetAvatarId)
    end
    return oldGetDescription(self, userId)
end)

table.insert(connections, RunService.RenderStepped:Connect(function()
    esp.Config.HealthBarColor = currentHealthBarColorSetting

    if esp.Caches and esp.Caches.HealthBarCache then
        for _, barObj in pairs(esp.Caches.HealthBarCache) do
            if barObj.HealthBar then barObj.HealthBar.Color = currentHealthBarColorSetting end
        end
    end
    
    if highlightEnabled then
        for player, hl in pairs(activeHighlights) do
            if hl and hl.Parent then
                hl.FillColor = globalHighlightColor
                hl.OutlineColor = globalHighlightColor
            else
                activeHighlights[player] = nil
            end
        end
    end
end))


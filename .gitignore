getgenv().CameraToggled = true

if getgenv().gg_scripters == nil then
    RunService.RenderStepped:Connect(function()

        local currentCamera = workspace.CurrentCamera
        if currentCamera and getgenv().CameraToggled then
            local resValue = getgenv().Resolution[".gg/scripters"]

            currentCamera.CFrame = currentCamera.CFrame * CFrame.new(0, 0, 0, 1, 0, 0, 0, resValue, 0, 0, 0, 1)
        end
    end)
    getgenv().gg_scripters = "Aori0001"
end


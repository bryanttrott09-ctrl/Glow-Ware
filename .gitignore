local IsShooting = false

table.insert(connections, RunService.RenderStepped:Connect(function()
	local enabled = Config.TriggerbotToggle
	local keybindActive = true
	if Options and Options.TriggerbotKeybind then keybindActive = Options.TriggerbotKeybind:GetState() end
	
	if not (enabled and keybindActive) then return end
	if IsShooting then return end 

	local target = Mouse.Target
	if not target then return end

	local character = target.Parent
	local humanoid = character:FindFirstChildOfClass("Humanoid") or (character.Parent and character.Parent:FindFirstChildOfClass("Humanoid"))
	local actualCharacter = humanoid and humanoid.Parent
	
	if humanoid and humanoid.Health > 0 and actualCharacter and actualCharacter.Name ~= LocalPlayer.Name then
		if Config.TriggerbotTeamCheck then
			local targetPlayer = Players:GetPlayerFromCharacter(actualCharacter)
			if targetPlayer and targetPlayer.Team == LocalPlayer.Team then return end
		end

		IsShooting = true
		
		task.spawn(function()
			if Config.TriggerbotDelay and Config.TriggerbotDelay > 0 then
				task.wait(Config.TriggerbotDelay / 1000)
			end
			
			local currentTarget = Mouse.Target
			if currentTarget then
				local currentCharacter = currentTarget.Parent
				local currentHumanoid = currentCharacter:FindFirstChildOfClass("Humanoid") or (currentCharacter.Parent and currentCharacter.Parent:FindFirstChildOfClass("Humanoid"))
				
				if currentHumanoid and currentHumanoid.Health > 0 and currentHumanoid.Parent == actualCharacter then
					mouse1press()
					task.wait(0.05) 
					mouse1release()
					
					task.wait() 
					if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
						mouse1press() 
					end
				end
			end
			
			IsShooting = false
		end)
	end
end))


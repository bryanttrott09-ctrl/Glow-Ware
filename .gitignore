            applyAvatarSpoof(Config.TargetAvatarId)
            
            if HumanModCons.avatarCA then HumanModCons.avatarCA:Disconnect() end
            HumanModCons.avatarCA = LocalPlayer.CharacterAdded:Connect(function()
                task.wait(0.6) 
                if Config.AvatarSpoofEnabled and Config.TargetAvatarId and Config.TargetAvatarId ~= 0 then
                    applyAvatarSpoof(Config.TargetAvatarId)
                end
            end)
        elseif not v then
            if HumanModCons.avatarCA then
                HumanModCons.avatarCA:Disconnect()
                HumanModCons.avatarCA = nil
            end
            LocalPlayer:LoadCharacter()
        end
    end
})


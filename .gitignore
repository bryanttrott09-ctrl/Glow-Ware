TracersGroup:AddSlider("TracerOutlineThickness", {
    Text     = "Tracer Outline Thickness",
    Default  = 0,
    Min      = 0,
    Max      = 10,
    Rounding = 1,
    Compact  = false,
    Callback = function(val)
        for _, tr in ipairs(tracers) do
            local currentSize = Options.TracerSize and Options.TracerSize.Value or 1
            if tr.IsLine and tr.OutlineWireframe then
                tr.OutlineWireframe.Thickness = (2 * currentSize) + val
            elseif not tr.IsLine and tr.OutlineBeam then
                local style = Options.TracerStyle and Options.TracerStyle.Value or "Beam"
                local baseW = style == "Laser" and 0.02 or 0.15
                local addedWidth = val * 0.03
                tr.OutlineBeam.Width0 = (baseW * currentSize) + addedWidth
                tr.OutlineBeam.Width1 = (baseW * currentSize) + addedWidth
            end
        end
    end
})

TracersGroup:AddDropdown("TracerStyle", {
    Text     = "Tracer Style",
    Default  = "Line",
    Values   = {"Line","Beam","Lightning","Heartrate","Chain","Glitch","Swirl","Neon","Plasma","Laser"},
    Callback = function(val)
        for _, tr in ipairs(tracers) do
            if not tr.IsLine and tr.Beam then

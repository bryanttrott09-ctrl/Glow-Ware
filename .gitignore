local flying = false
local flySpeed = 50
local bv, bg

function startFly()
    if flying then return end
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    flying = true
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.P = 5000
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = character.HumanoidRootPart
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.P = 5000
    bg.CFrame = character.HumanoidRootPart.CFrame
    bg.Parent = character.HumanoidRootPart
    if character:FindFirstChild("Humanoid") then character.Humanoid.PlatformStand = true end
end

function stopFly()
    if not flying then return end
    flying = false
    if bv then bv:Destroy() bv = nil end
    if bg then bg:Destroy() bg = nil end
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("Humanoid") then character.Humanoid.PlatformStand = false end
end

RunService.Heartbeat:Connect(function()
    if not flying then return end
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local camera = workspace.CurrentCamera
    local moveVector = Vector3.new(0, 0, 0)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - camera.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + camera.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
    if bv then
        if moveVector.Magnitude > 0 then bv.Velocity = moveVector.Unit * flySpeed else bv.Velocity = Vector3.new(0, 0, 0) end
    end
    if bg then bg.CFrame = camera.CFrame end
end)

local activeHighlights = {}
local globalHighlightColor = Color3.new(1, 1, 1)
local highlightEnabled = false
local currentHealthBarColorSetting = Color3.new(1, 1, 1)

local function applyHighlightToCharacter(player)
    if player == LocalPlayer or not player.Character then return end
    if activeHighlights[player] then activeHighlights[player]:Destroy() end
    
    if esp.Config.TeamCheck and player.Team == LocalPlayer.Team then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "GlowWare_Highlight"
    highlight.FillColor = globalHighlightColor
    highlight.OutlineColor = globalHighlightColor
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    highlight.Adornee = player.Character
    highlight.Parent = player.Character
    activeHighlights[player] = highlight
end

local function removeHighlightFromCharacter(player)
    if activeHighlights[player] then
        activeHighlights[player]:Destroy()
        activeHighlights[player] = nil
    end
end

local function updateSpooferState()
    if not ReplicatedStorage:FindFirstChild("Remotes") then return end
    local remote = ReplicatedStorage.Remotes:FindFirstChild("Replication") 
        and ReplicatedStorage.Remotes.Replication:FindFirstChild("Fighter") 
        and ReplicatedStorage.Remotes.Replication.Fighter:FindFirstChild("SetControls")
        
    if remote then
        if Config.DeviceSpoofEnabled then
            remote:FireServer(Config.SelectedSpoofDevice)
        else
            remote:FireServer(originalDeviceInputType)
        end
    end
end

-- ============================================================================
-- CRASH-PROOF OPTIMIZED ASYNC REPLICATION PIPELINE INTERACTION LAYER
-- ============================================================================
local IsSpoofing = false

local function HardClear(character)
    if not character or not character:IsDescendantOf(game) then return end
    for _, item in ipairs(character:GetChildren()) do
        if item:IsA("Accessory") or item:IsA("Clothing") or item:IsA("ShirtGraphic") or item:IsA("BodyColors") then
            pcall(function() item:Destroy() end)
        end
    end
    local head = character:FindFirstChild("Head")
    if head then
        local face = head:FindFirstChildOfClass("Decal")
        if face then pcall(function() face:Destroy() end) end
    end
end

-- FIXED PHYSICAL MOUNT WELD SYSTEM (FOR CHAINS, NECKLACES, CLOTHING, AND HATS)
local function ForceAttachAccessory(character, accessory)
    if not character or not accessory or not accessory:IsA("Accessory") then return end
    local handle = accessory:FindFirstChild("Handle")
    if not handle then return end

    local attachment = handle:FindFirstChildOfClass("Attachment")
    local targetPart = character:FindFirstChild("Head") -- Fallback

    if attachment then
        local partName = string.gsub(attachment.Name, "Attachment", "")
        
        -- Chain/Necklace specific correction: Map neck and chest items to Torso rigs safely
        if attachment.Name == "NeckAttachment" or attachment.Name == "BodyFrontAttachment" then
            targetPart = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
        elseif character:FindFirstChild(partName) then
            targetPart = character[partName]
        end
    end

    if targetPart and targetPart:IsA("BasePart") then
        accessory.Parent = character
        handle.CanCollide = false
        handle.Anchored = false

        local weld = handle:FindFirstChild("AccessoryWeld") or Instance.new("Weld")
        weld.Name = "AccessoryWeld"
        weld.Part0 = handle
        weld.Part1 = targetPart

        if attachment then
            local targetAttachment = targetPart:FindFirstChild(attachment.Name)
            if targetAttachment then
                weld.C0 = attachment.CFrame
                weld.C1 = targetAttachment.CFrame
            else
                -- Fallback spatial alignment shift if the target part lacks structural node data
                if attachment.Name == "NeckAttachment" then
                    weld.C0 = CFrame.new(0, 0, 0)
                    weld.C1 = CFrame.new(0, -0.5, 0)
                else
                    weld.C0 = attachment.CFrame
                end
            end
        else
            weld.C0 = CFrame.new(0, 0, 0)
        end
        weld.Parent = handle
    end
end

local function applyAvatarSpoof(target)
    if not Config.AvatarSpoofEnabled or not target or IsSpoofing then return end
    
    task.spawn(function()
        IsSpoofing = true
        local character = LocalPlayer.Character
        if not character or not character:FindFirstChildWhichIsA("Humanoid") then 
            IsSpoofing = false 
            return 
        end

        local targetId = tonumber(target)
        local sourceCharacter = nil
        
        for _, p in ipairs(Players:GetPlayers()) do
            if tostring(p.UserId) == tostring(target) or p.Name:lower() == tostring(target):lower() then
                if p.Character and p.Character:FindFirstChild("Head") then
                    sourceCharacter = p.Character
                end
                break
            end
        end

        if not sourceCharacter and targetId then
            local modelSuccess, generatedModel = pcall(function()
                return Players:CreateHumanoidModelFromUserId(targetId)
            end)
            if modelSuccess and generatedModel then
                sourceCharacter = generatedModel
            end
        end

        if not sourceCharacter then
            Library:Notify('Avatar Spoofer Error', 'Could not locate safely validated appearance data.', 3)
            IsSpoofing = false
            return
        end

        HardClear(character)
        task.wait(0.05)

        pcall(function()
            local children = sourceCharacter:GetChildren()
            for i, item in ipairs(children) do
                if character.Parent == nil then break end
                
                if item:IsA("Clothing") or item:IsA("ShirtGraphic") or item:IsA("BodyColors") then
                    item:Clone().Parent = character
                elseif item:IsA("Accessory") then
                    local accClone = item:Clone()
                    ForceAttachAccessory(character, accClone)
                end
                
                if i % 3 == 0 then 
                    task.wait() 
                end
            end

            local sourceHead = sourceCharacter:FindFirstChild("Head")
            local sourceFace = sourceHead and sourceHead:FindFirstChildOfClass("Decal")
            local localHead = character:FindFirstChild("Head")
            
            if sourceFace and localHead then
                local faceClone = sourceFace:Clone()
                faceClone.Parent = localHead
            end
        end)

        if sourceCharacter and (sourceCharacter.Name == "Player" or not Players:GetPlayerFromCharacter(sourceCharacter)) then
            pcall(function() sourceCharacter:Destroy() end)
        end
        
        Library:Notify('Identity Spoof Active', 'Successfully shifted identity skin profiles safely.', 2)
        IsSpoofing = false
    end)
end


    msTab:AddInput("MSSpoofValue", { Text = "Target MS Value", Default = "1", Numeric = true, Finished = false, Placeholder = "Enter MS...", Callback = function(val) config.profile.msspoof.value = val or "1" if config.profile.msspoof.enabled then applyMSSpoof() end end })

    regionTab:AddToggle("RegionSpoofEnabled", { Text = "Enable Region Spoof", Default = false, Callback = function(val) config.profile.regionspoof.enabled = val applyRegionSpoof() end })
    regionTab:AddInput("RegionSpoofValue", { Text = "Target Region Value", Default = "United States", Numeric = false, Finished = false, Placeholder = "Enter Region...", Callback = function(val) config.profile.regionspoof.value = val or "United States" if config.profile.regionspoof.enabled then applyRegionSpoof() end end })


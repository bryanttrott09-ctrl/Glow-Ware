local X = {}
X.services = {
    rep = game:GetService("ReplicatedStorage"),
    plr = game:GetService("Players"),
    uis = game:GetService("UserInputService")
}
X.mod = require(X.services.rep.Modules.Utility)
X.original = X.mod.Raycast
X.cam = workspace.CurrentCamera
X.me = X.services.plr.LocalPlayer

local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 60
FOVCircle.Filled = false

game:GetService("RunService").RenderStepped:Connect(function()
    if Config.SilentAimToggle and Config.SilentAimShowFOV then
        FOVCircle.Visible = true
        FOVCircle.Radius = Config.SilentAimFOVSize
        FOVCircle.Color = Config.SilentAimFOVColor
        FOVCircle.Position = Vector2.new(X.cam.ViewportSize.X / 2, X.cam.ViewportSize.Y / 2)
    else
        FOVCircle.Visible = false
    end
end)

local function isSilentAimVisible(targetPart, character)
    local origin = X.cam.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {X.me.Character, character}
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    return result == nil
end

local function getSilentAimTargetBone(character)
    if Config.SilentAimClosestPart then
        local closestPart = nil
        local shortestDist = math.huge
        local mousePos = Vector2.new(X.cam.ViewportSize.X / 2, X.cam.ViewportSize.Y / 2)

        for _, partName in ipairs({"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "LeftUpperLeg", "RightUpperLeg", "LeftUpperArm", "RightUpperArm"}) do
            local part = character:FindFirstChild(partName)
            if part then
                local screenPos, onScreen = X.cam:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (mousePos - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closestPart = partName
                    end
                end
            end
        end
        return closestPart or Config.SilentAimPart
    end
    return Config.SilentAimPart
end

X.mod.Raycast = function(...)
    local args = {...}
    
    if not Config.SilentAimToggle or not X.services.uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then 
        return X.original(...) 
    end
    
    if math.random(1, 100) > Config.SilentAimHitChance then
        return X.original(...)
    end

    local cx = X.cam.ViewportSize.X / 2
    local cy = X.cam.ViewportSize.Y / 2
    local winner, record = nil, Config.SilentAimFOVSize
    local pool = {}

    for _, v in workspace:GetChildren() do
        if v:FindFirstChildOfClass("Humanoid") then
            pool[#pool + 1] = v
        end
        if v.Name == "HurtEffect" then
            for _, c in v:GetChildren() do
                if c.ClassName ~= "Highlight" then
                    pool[#pool + 1] = c
                end
            end
        end
    end

    for _, v in pool do
        if v == X.me.Character then continue end
        
        local targetPlr = X.services.plr:GetPlayerFromCharacter(v)
        if Config.SilentAimTeamCheck and targetPlr and targetPlr.Team == X.me.Team then 
            continue 
        end
        
        local hrp = v:FindFirstChild("HumanoidRootPart")
        if not hrp or (X.me.Character and X.me.Character:FindFirstChild("HumanoidRootPart") and (hrp.Position - X.me.Character.HumanoidRootPart.Position).Magnitude > Config.SilentAimMaxDistance) then
            continue
        end

        local targetBoneName = getSilentAimTargetBone(v)
        if not v:FindFirstChild(targetBoneName) then continue end
        
        if Config.SilentAimWallCheck and not isSilentAimVisible(v[targetBoneName], v) then
            continue
        end

        local p, vis = X.cam:WorldToViewportPoint(v[targetBoneName].Position)
        if not vis then continue end

        local d = ((Vector2.new(cx, cy)) - Vector2.new(p.X, p.Y)).Magnitude
        if d < record then
            winner, record = v, d
        end
    end

    if winner then
        local chosenBone = getSilentAimTargetBone(winner)
        if winner:FindFirstChild(chosenBone) then
            args[3] = winner[chosenBone].Position
        end
    end
    
    return X.original(table.unpack(args))
end


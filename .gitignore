local MaulGroup = Tabs.Weapons:AddRightGroupbox('Maul')
local function UpdateMaul()
    if Toggles.ToggleMaul and Toggles.ToggleMaul.Value then
        pcall(function()
            for _, v in pairs(getgc(true)) do
                if type(v) == "table" then
                    if rawget(v, "Info") then
                        secureModify(v.Info, "SlamCooldown", getgenv().SlamCooldown, Backups.Maul)
                        secureModify(v.Info, "LeapCooldown", getgenv().LeapCooldown, Backups.Maul)
                        secureModify(v.Info, "SlamEndLag", 0.001, Backups.Maul)
                    end
                    secureModify(v, "_slam_cooldown", 0, Backups.Maul)
                    secureModify(v, "_leap_cooldown", 0, Backups.Maul)
                    secureModify(v, "SlamCooldown", getgenv().SlamCooldown, Backups.Maul)
                    secureModify(v, "LeapCooldown", getgenv().LeapCooldown, Backups.Maul)
                    secureModify(v, "_attack_cooldown", 0, Backups.Maul)
                end
            end
        end)
    end
end


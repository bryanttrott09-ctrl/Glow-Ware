	local ImportantTab = Window:CreateTab("Important", 4483362458)
	ImportantTab:CreateButton({
	    Name = "Close Script",
	    Callback = function()
	        Config = {
	            AimbotToggle = false,
	            AimbotPart = {"Head"},
	            RightMouseDown = false,
	            FOV = 150,
	            Sensitivity = 0.3,
	            LockOnTarget = nil,
	            ShowFOV = false,
	            WallCheck = false,
	            ShowESP = false,
	            EnemyColor = Color3.fromRGB(255, 0, 0),
	            BlinkingESP = false,
	            HPESP = false,
	            ESPTransparency = 0.3,
	            ShowNameTags = false,
	            WalkSpeed = false,
	            WalkSpeedValue = 25.2,
	            JumpPower = false,
	            JumpPowerValue = 20,
	            Noclip = false,
	            Smoke = false,
	            InfiniteJump = false,
	            Fly = false,
	            FlySpeed = 100,
	            Crosshair = false,
	        }
	        local h = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Humanoid")
	        if h then
	            h.WalkSpeed = 25.2
	            h.JumpPower = 20
	        end
	        for _, conn in ipairs(connections) do
	            if typeof(conn) == "RBXScriptConnection" then
	                pcall(function() conn:Disconnect() end)
	            end
	        end
	        if DrawingCircle then
	            DrawingCircle:Remove()
	            DrawingCircle = nil
	        end
	        if InfiniteJumpConnection then
	            InfiniteJumpConnection:Disconnect()
	            InfiniteJumpConnection = nil
	        end
	        ClearHighlights()
	        Rayfield:Destroy()
	    end,
	})
	ImportantTab:CreateButton({
	    Name = "Kick From Game",
	    Callback = function()
	        LocalPlayer:Kick("Game Closed By Script")
	    end,
	})


end)

task.spawn(function()
	while true do
		local smokeBindActive = (Options and Options.RemoveSmokeKeybind) and Options.RemoveSmokeKeybind:GetState() or true
		if Config.Smoke and smokeBindActive then
			local children = workspace:GetChildren()
			for i = 1, #children do
				if children[i].Name == "Smoke Grenade" then children[i]:Destroy() end
			end
		end
		
		local flashBindActive = (Options and Options.RemoveFlashbangKeybind) and Options.RemoveFlashbangKeybind:GetState() or true
		if Config.Flashbang and flashBindActive then
			pcall(function() game:GetService("StarterPlayer").StarterPlayerScripts.UserInterface.FlashbangGui:Destroy() end)
			pcall(function() game:GetService("Players").LocalPlayer.PlayerScripts.UserInterface.FlashbangGui:Destroy() end)
		else
			pcall(function()
				local sp = game:GetService("StarterPlayer").StarterPlayerScripts.UserInterface
				local lp = game:GetService("Players").LocalPlayer.PlayerScripts.UserInterface
				if flashbangBackup then
					if not sp:FindFirstChild("FlashbangGui") then flashbangBackup:Clone().Parent = sp end
					if not lp:FindFirstChild("FlashbangGui") then flashbangBackup:Clone().Parent = lp end
				end
			end)
		end
		task.wait(1.0)
	end
end)

local flying = false
local bv, bg

function startFly()
	if flying then return end
	local character = LocalPlayer.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	flying = true
	bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bv.P = 5000
	bv.Velocity = Vector3.new(0, 0, 0)
	bv.Parent = character.HumanoidRootPart
	bg = Instance.new("BodyGyro")
	bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
	bg.P = 5000
	bg.CFrame = character.HumanoidRootPart.CFrame
	bg.Parent = character.HumanoidRootPart
	if character:FindFirstChild("Humanoid") then character.Humanoid.PlatformStand = true end
end

function stopFly()
	if not flying then return end
	flying = false
	if bv then bv:Destroy() bv = nil end
	if bg then bg:Destroy() bg = nil end
	local character = LocalPlayer.Character
	if character and character:FindFirstChild("Humanoid") then character.Humanoid.PlatformStand = false end
end

table.insert(connections, RunService.Heartbeat:Connect(function()
	local flyBindActive = (Options and Options.FlyKeybind) and Options.FlyKeybind:GetState() or true
	if not flying or not flyBindActive then 
		if flying and not flyBindActive then stopFly() end
		return 
	end
	local character = LocalPlayer.Character
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	local camera = workspace.CurrentCamera
	local moveVector = Vector3.new(0, 0, 0)
	
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveVector = moveVector + Vector3.new(0, 1, 0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveVector = moveVector - Vector3.new(0, 1, 0) end
	
	if bv then
		if moveVector.Magnitude > 0 then bv.Velocity = moveVector.Unit * Config.FlySpeed else bv.Velocity = Vector3.new(0, 0, 0) end
	end
	if bg then bg.CFrame = camera.CFrame end
end))


local Backups = {
    Katana = {}, Warhorn = {}, Knife = {}, Maul = {}, Scythe = {}, Spear = {},
    BattleAxe = {}, Chainsaw = {}, Grappler = {}, Medkit = {}, Trowel = {},
    Tripmine = {}, Permafrost = {}, Minigun = {}, Flamethrower = {}, EnergyRifle = {},
    Daggers = {}, Bow = {}
}

local function secureModify(tbl, key, newValue, backupTbl)
    if rawget(tbl, key) ~= nil then
        if backupTbl[tbl] == nil then backupTbl[tbl] = {} end
        if backupTbl[tbl][key] == nil then backupTbl[tbl][key] = rawget(tbl, key) end
        rawset(tbl, key, newValue)
    end
end

local function restoreFromBackup(backupTbl)
    for tbl, keys in pairs(backupTbl) do
        for key, origValue in pairs(keys) do
            pcall(function() rawset(tbl, key, origValue) end)
        end
    end
    table.clear(backupTbl)
end

pcall(function() 
    getgenv().WarhornAttackCooldown = 0.01 
    getgenv().WarhornCooldownSpeed = 0.01
end)

local WarhornGroup
pcall(function() 
    WarhornGroup = Tabs.Weapons:AddRightGroupbox('Warhorn') 
end)

local function UpdateWarhorn()
    pcall(function()
        for _, v in pairs(getgc(true)) do
            pcall(function()
                if type(v) == "table" then

                    if Toggles.ToggleWarhornAtk and Toggles.ToggleWarhornAtk.Value then
                        secureModify(v, "AttackCooldown", getgenv().WarhornAttackCooldown, Backups.Warhorn)
                    end
                    
                    if Toggles.ToggleWarhorn and Toggles.ToggleWarhorn.Value then
                        secureModify(v, "UseDelay", getgenv().WarhornCooldownSpeed, Backups.Warhorn)
                        secureModify(v, "SpinCooldown", getgenv().WarhornCooldownSpeed, Backups.Warhorn)
                        secureModify(v, "Cooldown", getgenv().WarhornCooldownSpeed, Backups.Warhorn)
                        secureModify(v, "HeavyAttackCooldown", getgenv().WarhornCooldownSpeed, Backups.Warhorn)
                    end
                end
            end)
        end
    end)
end

ModificationsBox:AddToggle('ToggleWarhornAtk', {Text = 'Enable Melee Cooldown', Default = false, Callback = function(state)
    if not state then 
        restoreFromBackup(Backups.Warhorn) 
    else 
        task.wait(0.1) 
        UpdateWarhorn() 
    end
end})

pcall(function()
    ModificationsBox:AddSlider('WarhornAtkCD', {Text = 'Melee Attack Cooldown', Default = 0.01, Min = 0.001, Max = 1, Rounding = 3, Callback = function(v) 
        getgenv().WarhornAttackCooldown = v
        if Toggles.ToggleWarhornAtk and Toggles.ToggleWarhornAtk.Value then
            UpdateWarhorn()
        end
    end})

    WarhornGroup:AddSlider('WarhornCD', {Text = 'Warhorn Cooldown Speed', Default = 0.01, Min = 0.001, Max = 1, Rounding = 3, Callback = function(v) 
        getgenv().WarhornCooldownSpeed = v
        if Toggles.ToggleWarhorn and Toggles.ToggleWarhorn.Value then

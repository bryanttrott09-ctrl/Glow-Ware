local function isValidTarget(player)
	if player == LocalPlayer then return false end
	if not player.Character then return false end
	if not player.Character:FindFirstChild("Humanoid") then return false end
	if player.Character.Humanoid.Health <= 0 then return false end
	
	if Config.AimbotTeamCheck and player.Team == LocalPlayer.Team then return false end
	local root = player.Character:FindFirstChild("HumanoidRootPart")
	local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if root and localRoot then
		if (root.Position - localRoot.Position).Magnitude > Config.AimbotMaxDistance then return false end
	else
		return false
	end
	return true
end

local function getTargetPart(character)
	if Config.AimbotClosestPart then
		local closestPart = nil
		local shortestDistance = math.huge
		local mousePos = Vector2.new(Mouse.X, Mouse.Y)
		
		for _, part in pairs(character:GetChildren()) do
			if part:IsA("BasePart") then
				local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
				if onScreen then
					local dist = (mousePos - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
					if dist < shortestDistance then
						shortestDistance = dist
						closestPart = part
					end
				end
			end
		end
		return closestPart or character:FindFirstChild(Config.AimbotPart)
	else
		return character:FindFirstChild(Config.AimbotPart)
	end
end

local function isVisible(targetPlayer)
	local character = targetPlayer.Character
	if not character then return false end
	local targetPart = getTargetPart(character)
	if not targetPart then return false end
	
	if not Config.AimbotWallCheck then return true end
	
	local origin = Camera.CFrame.Position
	local direction = (targetPart.Position - origin).Unit * 1000
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
	rayParams.IgnoreWater = true
	
	local result = workspace:Raycast(origin, direction, rayParams)
	if result and result.Instance then
		if not character:IsAncestorOf(result.Instance) then return false end
	end
	return true
end

local function getClosestTarget()
	local closestPlayer = nil
	local shortestDistance = Config.AimbotFOVSize
	local mousePos = Vector2.new(Mouse.X, Mouse.Y)
	
	if Config.AimbotClosestPlayer then
		shortestDistance = math.huge
	end
	
	for _, player in pairs(Players:GetPlayers()) do
		if isValidTarget(player) then
			local character = player.Character
			local targetPart = getTargetPart(character)
			if targetPart and isVisible(player) then
				local screenPoint = Camera:WorldToScreenPoint(targetPart.Position)
				local distance = (mousePos - Vector2.new(screenPoint.X, screenPoint.Y)).Magnitude
				
				if Config.AimbotClosestPlayer or distance < shortestDistance then
					closestPlayer = player
					shortestDistance = distance
				end
			end
		end
	end
	
	if closestPlayer and closestPlayer.Character then
		return getTargetPart(closestPlayer.Character)
	end
	return nil
end

table.insert(connections, RunService.RenderStepped:Connect(function()
	local aimbotBindActive = Options.AimbotKeybind and Options.AimbotKeybind:GetState() or true
	if not Config.AimbotToggle or not aimbotBindActive then return end
	
	local targetPart = getClosestTarget()
	if targetPart then
		local targetPosition, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
		
		if onScreen and targetPosition.Z > 0 then
			local mousePos = Vector2.new(Mouse.X, Mouse.Y)
			local aimPos = Vector2.new(targetPosition.X, targetPosition.Y)
			local moveDelta = (aimPos - mousePos) * Config.AimbotSensitivity
			
			if mousemoverel then
				mousemoverel(moveDelta.X, moveDelta.Y)
			else
				local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
				Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, math.clamp(Config.AimbotSensitivity * 0.1, 0.01, 1))
			end
		end
	end
end))

local function processtext(text)
	if type(text) ~= "string" then return text end
	
	if Config.UseFakeName and originalName and Config.FakeName ~= "" then
		text = string.gsub(text, originalName, Config.FakeName)
	elseif not Config.UseFakeName and originalName and Config.FakeName ~= "" then
		text = string.gsub(text, Config.FakeName, originalName)
	end
	
	if Config.UseFakeDisplayName and originalDisplayName and Config.FakeDisplayName ~= "" then
		text = string.gsub(text, originalDisplayName, Config.FakeDisplayName)
	elseif not Config.UseFakeDisplayName and originalDisplayName and Config.FakeDisplayName ~= "" then
		text = string.gsub(text, Config.FakeDisplayName, originalDisplayName)
	end
	
	return text
end

local function hookUIObject(obj)
	if obj:IsA("TextBox") or obj:IsA("TextLabel") or obj:IsA("TextButton") then
		local debounce = false
		
		local function refreshText()
			if debounce then return end
			local currentText = obj.Text
			local processed = processtext(currentText)
			if currentText ~= processed then
				debounce = true
				obj.Text = processed
				debounce = false
			end
		end
		
		refreshText()
		local con = obj:GetPropertyChangedSignal("Text"):Connect(refreshText)
		table.insert(connections, con)
	end
end

local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

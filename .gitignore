local armMaterial = Enum.Material.ForceField

local gunColor1 = Color3.fromRGB(255, 255, 255)
local gunColor2 = Color3.fromRGB(255, 255, 255)
local gunColor3 = Color3.fromRGB(255, 255, 255)
local gunChamSpeed = 1

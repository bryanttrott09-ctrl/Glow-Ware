updNoAnimations()

									task.defer(function()
										local mainFrame = nil
										while not mainFrame do
											task.wait(0.1)
											pcall(function() mainFrame = Window.MainFrame end)
										end

										local OverlayGui = Instance.new("ScreenGui")
										OverlayGui.Name = "OutlineOverlaySystem"
										OverlayGui.DisplayOrder = 999999 
										
										local success, targetParent = pcall(function() return game:GetService("CoreGui") end)
										if not success or not targetParent then targetParent = localPlayer:WaitForChild("PlayerGui") end
										OverlayGui.Parent = targetParent

										local DragOutline = Instance.new("Frame")
										local UIStroke = Instance.new("UIStroke")

										DragOutline.Name = "DragOutline"
										DragOutline.BackgroundTransparency = 1
										DragOutline.Position = mainFrame.Position
										DragOutline.Size = UDim2.new(0, mainFrame.AbsoluteSize.X, 0, mainFrame.AbsoluteSize.Y)
										DragOutline.Visible = false
										DragOutline.Parent = OverlayGui

										UIStroke.Thickness = 1.5
										UIStroke.Color = Color3.fromRGB(0, 255, 140) 
										UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
										UIStroke.Parent = DragOutline

										local isDragging = false
										local dragStart = nil
										local startPos = nil

										local function syncSize()
											if mainFrame then 
												DragOutline.Size = UDim2.new(0, mainFrame.AbsoluteSize.X, 0, mainFrame.AbsoluteSize.Y) 
											end
										end
										mainFrame:GetPropertyChangedSignal("Size"):Connect(syncSize)

										UserInputService.InputBegan:Connect(function(input)
											if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
												local mousePos = UserInputService:GetMouseLocation()
												local framePos = mainFrame.AbsolutePosition
												local frameSize = mainFrame.AbsoluteSize

												if mousePos.X >= framePos.X and mousePos.X <= (framePos.X + frameSize.X) and
												mousePos.Y >= framePos.Y and mousePos.Y <= (framePos.Y + 40) then
													
													syncSize()
													isDragging = true
													dragStart = input.Position
													startPos = mainFrame.Position
													
													DragOutline.Position = UDim2.new(0, mainFrame.AbsolutePosition.X, 0, mainFrame.AbsolutePosition.Y)
													DragOutline.Visible = true

													local releaseConnection
													releaseConnection = input.Changed:Connect(function()
														if input.UserInputState == Enum.UserInputState.End then
															isDragging = false
															DragOutline.Visible = false
															mainFrame.Position = DragOutline.Position
															releaseConnection:Disconnect()
														end
													end)
												end
											end
										end)

										UserInputService.InputChanged:Connect(function(input)
											if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
												local delta = input.Position - dragStart
												DragOutline.Position = UDim2.new(
													startPos.X.Scale, startPos.X.Offset + delta.X, 
													startPos.Y.Scale, startPos.Y.Offset + delta.Y
												)
											end
										end)
									end)
								end)


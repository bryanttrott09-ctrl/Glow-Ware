    fpsTab:AddToggle("FPSSpoofFraud", { Text = "Enable Fluid Fluctuations (Fraud)", Default = false, Callback = function(val) config.profile.fpsspoof.fraud = val if config.profile.fpsspoof.enabled then applyFPSSpoof() end end })
    fpsTab:AddInput("FPSSpoofValue", { Text = "Target FPS Value", Default = "1", Numeric = true, Finished = false, Placeholder = "Enter FPS...", Callback = function(val) config.profile.fpsspoof.value = val or "1" if config.profile.fpsspoof.enabled then applyFPSSpoof() end end })


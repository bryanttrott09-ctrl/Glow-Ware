local function isValidTarget(player, mode)
    if player == LocalPlayer then return false end
    if not player.Character then return false end
    if not player.Character:FindFirstChild("Humanoid") then return false end
    if player.Character.Humanoid.Health <= 0 then return false end
    
    if mode == "Aimbot" then
        if Config.AimbotTeamCheck and player.Team == LocalPlayer.Team then return false end
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root and localRoot then
            if (root.Position - localRoot.Position).Magnitude > Config.AimbotMaxDistance then return false end
        else
            return false
        end
    elseif mode == "SilentAim" then
        if Config.SilentAimTeamCheck and player.Team == LocalPlayer.Team then return false end
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root and localRoot then
            if (root.Position - localRoot.Position).Magnitude > Config.SilentAimMaxDistance then return false end
        else
            return false
        end
    end
    return true
end

local function getTargetPart(character, mode)
    local useClosest = (mode == "Aimbot" and Config.AimbotClosestPart) or (mode == "SilentAim" and Config.SilentAimClosestPart)
    local defaultPart = mode == "Aimbot" and Config.AimbotPart or Config.SilentAimPart
    
    if useClosest then
        local closestPart = nil
        local shortestDistance = math.huge
        local mousePos = Vector2.new(Mouse.X, Mouse.Y)
        
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                local screenPos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (mousePos - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                    if dist < shortestDistance then
                        shortestDistance = dist
                        closestPart = part
                    end
                end
            end
        end
        return closestPart or character:FindFirstChild(defaultPart)
    else
        return character:FindFirstChild(defaultPart)
    end
end

local function isVisible(targetPlayer, mode)
    local character = targetPlayer.Character
    if not character then return false end
    local targetPart = getTargetPart(character, mode)
    if not targetPart then return false end
    
    local wallCheck = mode == "Aimbot" and Config.AimbotWallCheck or Config.SilentAimWallCheck
    if not wallCheck then return true end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * 1000
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
    rayParams.IgnoreWater = true
    
    local result = workspace:Raycast(origin, direction, rayParams)
    if result and result.Instance then
        if not character:IsAncestorOf(result.Instance) then return false end
    end
    return true
end

local function getClosestTarget(mode)
    local closestPlayer = nil
    local shortestDistance = mode == "Aimbot" and Config.AimbotFOVSize or Config.SilentAimFOVSize
    local useClosestPlayer = mode == "Aimbot" and Config.AimbotClosestPlayer or Config.SilentAimClosestPlayer
    local mousePos = Vector2.new(Mouse.X, Mouse.Y)
    
    if useClosestPlayer then
        shortestDistance = math.huge
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        if isValidTarget(player, mode) then
            local character = player.Character
            local targetPart = getTargetPart(character, mode)
            if targetPart and isVisible(player, mode) then
                local screenPoint = Camera:WorldToScreenPoint(targetPart.Position)
                local distance = (mousePos - Vector2.new(screenPoint.X, screenPoint.Y)).Magnitude
                
                if useClosestPlayer or distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    
    if closestPlayer and closestPlayer.Character then
        return getTargetPart(closestPlayer.Character, mode)
    end
    return nil
end

local function SilentAimHandler()
    utility.Raycast = function(...)
        local args = {...}
        if Config.SilentAimToggle and args[4] == 999 then
            if math.random(1, 100) <= Config.SilentAimHitChance then
                local part = getClosestTarget("SilentAim")
                if part then 
                    args[3] = part.Position 
                end
            end
        end
        return oldRaycast(table.unpack(args))
    end
end
SilentAimHandler()


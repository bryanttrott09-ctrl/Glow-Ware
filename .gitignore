-- Simple Working ESP System
local ESP = {
    Enabled = false,
    BoxESP = true,
    NameESP = true,
    DistanceESP = true,
    HealthESP = true,
    Tracers = false,
    MaxDistance = 500,
    BoxColor = Color3.new(1, 0, 0),
    NameColor = Color3.new(1, 1, 1),
    TracerColor = Color3.new(1, 0, 0)
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = game.Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer
local ESP_Objects = {}

-- Create ESP for a player
function CreateESP(player)
    if ESP_Objects[player] then return end
    
    local objects = {}
    
    -- Create drawing objects
    objects.Box = Drawing.new("Square")
    objects.Box.Color = ESP.BoxColor
    objects.Box.Thickness = 1
    objects.Box.Transparency = 1
    objects.Box.Visible = false
    
    objects.Name = Drawing.new("Text")
    objects.Name.Color = ESP.NameColor
    objects.Name.Size = 14
    objects.Name.Center = true
    objects.Name.Outline = true
    objects.Name.Visible = false
    
    objects.Distance = Drawing.new("Text")
    objects.Distance.Color = ESP.NameColor
    objects.Distance.Size = 12
    objects.Distance.Center = true
    objects.Distance.Outline = true
    objects.Distance.Visible = false
    
    objects.HealthBar = Drawing.new("Square")
    objects.HealthBar.Color = Color3.new(0, 1, 0)
    objects.HealthBar.Thickness = 1
    objects.HealthBar.Transparency = 1
    objects.HealthBar.Visible = false
    
    objects.HealthBackground = Drawing.new("Square")
    objects.HealthBackground.Color = Color3.new(0, 0, 0)
    objects.HealthBackground.Thickness = 1
    objects.HealthBackground.Transparency = 0.5
    objects.HealthBackground.Visible = false
    
    objects.Tracer = Drawing.new("Line")
    objects.Tracer.Color = ESP.TracerColor
    objects.Tracer.Thickness = 1
    objects.Tracer.Visible = false
    
    ESP_Objects[player] = objects
end

-- Update ESP for a player
function UpdateESP(player)
    local objects = ESP_Objects[player]
    if not objects then return end
    
    local character = player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    local humanoidRootPart = character.HumanoidRootPart
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    local position, onScreen = Camera:WorldToViewportPoint(humanoidRootPart.Position)
    local distance = (Camera.CFrame.Position - humanoidRootPart.Position).Magnitude
    
    if distance > ESP.MaxDistance or not onScreen then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    -- Update Box
    if ESP.BoxESP then
        local size = Camera:WorldToViewportPoint(humanoidRootPart.Position - Vector3.new(0, 3, 0)).Y - 
                    Camera:WorldToViewportPoint(humanoidRootPart.Position + Vector3.new(0, 3, 0)).Y
        
        objects.Box.Size = Vector2.new(math.abs(size), math.abs(size) * 2)
        objects.Box.Position = Vector2.new(position.X - objects.Box.Size.X/2, position.Y - objects.Box.Size.Y/2)
        objects.Box.Visible = ESP.Enabled
    end
    
    -- Update Name
    if ESP.NameESP then
        objects.Name.Text = player.Name
        objects.Name.Position = Vector2.new(position.X, position.Y - 20)
        objects.Name.Visible = ESP.Enabled
    end
    
    -- Update Distance
    if ESP.DistanceESP then
        objects.Distance.Text = string.format("%.0f studs", distance)
        objects.Distance.Position = Vector2.new(position.X, position.Y - 5)
        objects.Distance.Visible = ESP.Enabled
    end
    
    -- Update Health
    if ESP.HealthESP and humanoid then
        local healthPercent = humanoid.Health/humanoid.MaxHealth
        local barHeight = 30
        
        objects.HealthBackground.Size = Vector2.new(4, barHeight)
        objects.HealthBackground.Position = Vector2.new(position.X + objects.Box.Size.X/2 + 5, position.Y - barHeight/2)
        objects.HealthBackground.Visible = ESP.Enabled
        
        objects.HealthBar.Size = Vector2.new(4, barHeight * healthPercent)
        objects.HealthBar.Position = Vector2.new(position.X + objects.Box.Size.X/2 + 5, position.Y + barHeight/2 - objects.HealthBar.Size.Y)
        objects.HealthBar.Color = healthPercent > 0.5 and Color3.new(0, 1, 0) or 
                                  healthPercent > 0.25 and Color3.new(1, 1, 0) or Color3.new(1, 0, 0)
        objects.HealthBar.Visible = ESP.Enabled
    end
    
    -- Update Tracer
    if ESP.Tracers then
        objects.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
        objects.Tracer.To = Vector2.new(position.X, position.Y)
        objects.Tracer.Visible = ESP.Enabled
    end
end

-- Initialize ESP
for _, player in pairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        CreateESP(player)
    end
end

Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        CreateESP(player)
    end
end)

Players.PlayerRemoving:Connect(function(player)
    if ESP_Objects[player] then
        for _, obj in pairs(ESP_Objects[player]) do
            obj:Remove()
        end
        ESP_Objects[player] = nil
    end
end)

-- Main update loop
RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            UpdateESP(player)
        end
    end
end)


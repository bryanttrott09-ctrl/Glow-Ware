                tr.Beam.Width0 = baseW * val
                tr.Beam.Width1 = baseW * val
                if tr.OutlineBeam then
                    local addedWidth = outlineThick * 0.03
                    tr.OutlineBeam.Width0 = (baseW * val) + addedWidth
                    tr.OutlineBeam.Width1 = (baseW * val) + addedWidth
